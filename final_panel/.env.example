APP_NAME="SMM Elite"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smmelite
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mail.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@smmelite.com
MAIL_FROM_NAME="${APP_NAME}"

BREVO_API_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=

# ─────────────────────────────────────────────
# PAYMENT GATEWAY CREDENTIALS
# ─────────────────────────────────────────────

# Stripe Configuration
STRIPE_PUBLIC_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_test_

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=

# ─────────────────────────────────────────────
# AMI CONFIGURATION (Optional External Provider)
# ─────────────────────────────────────────────
AMI_API_KEY=
AMI_API_URL=https://api.ami.com/api

# ─────────────────────────────────────────────
# TELEGRAM INTEGRATION (Optional)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# AWS CONFIGURATION (For S3 storage if needed)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# ─────────────────────────────────────────────
# APPLICATION CONFIGURATION
# ─────────────────────────────────────────────
REFERRAL_COMMISSION_PERCENT=5
ADMIN_EMAIL=admin@smmelite.com
PAGINATION_PER_PAGE=20
MAX_ORDER_QUANTITY=10000000
MIN_DEPOSIT_AMOUNT=100
MAX_DEPOSIT_AMOUNT=500000

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
API_RATE_LIMIT=60
API_RATE_WINDOW=1
